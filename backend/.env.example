# Copy to .env and fill in. Never commit .env.

# --- LLM backends (per-tier) ---
# Each tier picks a backend: "hf" | "groq" | "openai". Override per tier:
#   FAST_BACKEND    = high-volume ranking prefilter (cheap model)
#   QUALITY_BACKEND = tailoring / application answers / deep score (strong model)
# Empty per-tier value falls back to LLM_BACKEND.
LLM_BACKEND=hf
FAST_BACKEND=groq
QUALITY_BACKEND=groq

# --- Groq (free tier, OpenAI-compatible) — https://console.groq.com/keys ---
GROQ_API_KEY=
GROQ_FAST_MODEL=llama-3.1-8b-instant
# 8B works for everything on the free tier; use llama-3.3-70b-versatile for
# richer tailoring if your quota allows.
GROQ_QUALITY_MODEL=llama-3.1-8b-instant

# --- Hugging Face Inference Providers ---
HF_TOKEN=hf_...
HF_QUALITY_MODEL=Qwen/Qwen2.5-72B-Instruct
HF_FAST_MODEL=meta-llama/Llama-3.1-8B-Instruct
HF_PROVIDER=novita

# --- Generic OpenAI-compatible backend (Ollama / Gemini / OpenRouter / OpenAI) ---
# Use with FAST_BACKEND/QUALITY_BACKEND=openai
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_FAST_MODEL=
OPENAI_QUALITY_MODEL=

# --- Adzuna job search (optional; free app id/key from developer.adzuna.com) ---
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us

# --- Database ---
# SQLite by default; swap for a Postgres URL to use a managed database.
DATABASE_URL=sqlite:///./job_applier.db
# Managed Postgres (e.g. Neon). The pooled URL + psycopg2 works as-is:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require

# --- Safety / autonomy ---
# When true, submission adapters fill forms but NEVER click final submit.
DRY_RUN=true
# Global kill switch. When true, no submissions happen at all.
SUBMIT_KILL_SWITCH=false
# Max applications submitted per calendar day.
DAILY_SUBMIT_CAP=40
# Minimum Opus match score (0-100) required to tailor + submit.
MATCH_THRESHOLD=70

# --- Orchestrator ---
# Minutes between orchestrator cycles.
CYCLE_INTERVAL_MINUTES=60\

# --- SMTP (daily summary email) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SUMMARY_EMAIL_TO=

# --- Paths ---
# Where uploaded resumes and generated artifacts are stored.
DATA_DIR=./data
